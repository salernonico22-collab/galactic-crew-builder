<!DOCTYPE html>

<html lang="it">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Federazione Galattica - Gestore Missioni</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&family=JetBrains+Mono:wght@300;500&display=swap" rel="stylesheet">

    <style>

        :root {

            --primary-accent: #60a5fa;

            --bg-deep: #020617;

            --surface: #0f172a;

            --text-main: #e2e8f0;

            --api-green: #22c55e;

            --api-red: #ef4444;

            --api-gray: #94a3b8;

        }



        body {

            background-color: var(--bg-deep);

            color: var(--text-main);

            font-family: 'Inter', sans-serif;

            margin: 0;

            overflow: hidden;

            min-height: 100vh;

            display: flex;

        }



        #space-background {

            position: fixed;

            inset: 0;

            z-index: 0;

            background-color: #020617;

            background-image:

                radial-gradient(circle at 50% 50%, rgba(15, 23, 42, 0.6) 0%, rgba(2, 6, 23, 1) 100%);

            pointer-events: none;

        }



        canvas#space-canvas {

            position: absolute;

            top: 0;

            left: 0;

            width: 100%;

            height: 100%;

        }



        .mono { font-family: 'JetBrains Mono', monospace; }



        #main-wrapper {

            flex: 1;

            height: 100vh;

            overflow-y: auto;

            display: flex;

            flex-direction: column;

            position: relative;

            z-index: 10;

        }



        .character-card {

            max-width: 280px;

            margin: 0 auto;

            width: 100%;

        }



        .portrait-container {

            position: relative;

            overflow: hidden;

            background: #000;

            height: 180px;

            display: flex;

            align-items: center;

            justify-content: center;

        }



        .portrait-bg-blur {

            position: absolute;

            inset: 0;

            width: 100%;

            height: 100%;

            object-fit: cover;

            filter: blur(20px) brightness(0.4);

            transform: scale(1.1);

            z-index: 1;

        }



        .portrait-img {

            position: relative;

            z-index: 5;

            width: 100%;

            height: 100%;

            object-fit: contain;

            object-position: center;

        }



        .hud-overlay {

            position: absolute;

            inset: 0;

            border: 1px solid rgba(0, 255, 255, 0.1);

            pointer-events: none;

            background: repeating-linear-gradient(0deg, transparent, transparent 1px, rgba(0, 255, 255, 0.03) 2px);

            background-size: 100% 3px;

            z-index: 10;

        }



        .glass-panel {

            background: rgba(15, 23, 42, 0.85);

            backdrop-filter: blur(16px);

            border: 1px solid rgba(255, 255, 255, 0.1);

            border-radius: 12px;

            overflow: hidden;

            transition: all 0.3s ease;

        }



        .status-alive { border-color: rgba(34, 197, 94, 0.4) !important; }

        .status-dead { border-color: rgba(239, 68, 68, 0.4) !important; opacity: 0.7; filter: grayscale(100%); }



        .dossier-details {

            max-height: 0;

            overflow: hidden;

            transition: max-height 0.3s ease;

        }



        .dossier-open .dossier-details {

            max-height: 150px;

            padding: 1rem;

            border-top: 1px solid rgba(255, 255, 255, 0.05);

        }



        .stat-bar-bg { height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; margin-top: 2px; }

        .stat-bar-fill { height: 100%; background: var(--primary-accent); border-radius: 2px; }



        .btn-action {

            background: rgba(96, 165, 250, 0.1);

            border: 1px solid var(--primary-accent);

            color: var(--primary-accent);

            transition: all 0.2s;

        }



        .btn-action:hover:not(:disabled) { background: var(--primary-accent); color: #000; }

        .btn-action:disabled { opacity: 0.4; cursor: not-allowed; border-color: #475569; color: #475569; }



        #mission-modal {

            position: fixed;

            inset: 0;

            background: rgba(0,0,0,0.9);

            z-index: 1000;

            display: none;

            align-items: center;

            justify-content: center;

            padding: 20px;

        }



        .modal-content {

            background: var(--surface);

            border: 2px solid var(--primary-accent);

            max-width: 500px;

            width: 100%;

            padding: 2rem;

            border-radius: 16px;

        }



        #history-dropdown summary {

            list-style: none;

            cursor: pointer;

        }

        #history-dropdown summary::-webkit-details-marker { display: none; }



        ::-webkit-scrollbar { width: 5px; }

        ::-webkit-scrollbar-thumb { background: var(--primary-accent); border-radius: 10px; }



        .spin-icon {

            transition: transform 0.5s ease;

        }

        .refresh-btn-group:hover .spin-icon {

            transform: rotate(180deg);

        }

    </style>

</head>

<body>



    <div id="space-background">

        <canvas id="space-canvas"></canvas>

    </div>



    <div id="main-wrapper">

        <header class="p-8 flex justify-between items-center border-b border-white/10 bg-slate-950/50 relative z-50">

            <div class="flex-grow">

                <h1 class="text-[10px] font-bold tracking-[0.5em] text-cyan-400 mb-2 mono uppercase opacity-80">Comando Missioni Spaziali</h1>

                <p class="text-4xl font-black tracking-tighter uppercase leading-none text-white drop-shadow-lg">Database Operativo Federale</p>

            </div>

           

            <div class="flex items-center gap-6">

                <details id="history-dropdown" class="relative">

                    <summary class="bg-slate-900 border border-white/20 px-6 py-3 rounded text-xs mono uppercase flex items-center gap-3 hover:border-cyan-400 transition-colors shadow-lg">

                        <span>Archivio Missioni</span>

                        <span class="text-cyan-400">▼</span>

                    </summary>

                    <div id="history-panel" class="absolute right-0 mt-3 glass-panel p-5 shadow-2xl z-[100] w-[400px]">

                        <h3 class="text-xs font-bold mb-4 border-b border-white/10 pb-2 uppercase text-slate-300 mono tracking-widest">Registri di Bordo</h3>

                        <div id="mission-history-content" class="space-y-3 max-height-[400px] overflow-y-auto">

                            <p class="text-xs text-slate-600 italic mono text-center py-8">In attesa di dati missione...</p>

                        </div>

                    </div>

                </details>

            </div>

        </header>



        <main class="p-6 grid grid-cols-1 xl:grid-cols-4 gap-8">

            <section id="main-content-area" class="xl:col-span-3 space-y-8">

                <div>

                    <!-- Riga orizzontale con Titolo e Bottone Refresh -->

                    <div class="flex justify-between items-center border-b border-white/10 mb-8 pb-2">

                        <button id="tab-title" onclick="toggleView()" class="text-xs font-bold mono uppercase flex items-center gap-2 transition-all hover:text-cyan-400">

                            <span id="tab-icon" class="w-2 h-2 bg-emerald-400 rounded-full animate-ping"></span>

                            <span id="tab-label">UNITÀ OPERATIVE DISPONIBILI</span>

                        </button>

                       

                        <button onclick="refreshRecruits()" class="refresh-btn-group flex items-center gap-3 text-[10px] font-bold mono text-slate-400 hover:text-cyan-400 transition-colors uppercase">

                            <span>aggiorna lista reclute</span>

                            <svg class="spin-icon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">

                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>

                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>

                            </svg>

                        </button>

                    </div>

                   

                    <div id="candidates-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 justify-items-center">

                        <!-- Caricamento dinamico -->

                    </div>

                </div>

            </section>



            <aside id="team-sidebar" class="xl:col-span-1 space-y-6">

                <div class="glass-panel p-6 border-cyan-500/30">

                    <h2 class="text-xs font-bold uppercase mb-6 flex justify-between mono">

                        Team Missione <span id="team-count" class="text-cyan-400">0 / 3</span>

                    </h2>

                    <div id="team-list" class="space-y-3 mb-6"></div>

                    <button id="launch-btn" disabled onclick="startMission()" class="w-full py-4 btn-action text-xs font-bold rounded uppercase tracking-widest">

                        Avvia Lancio

                    </button>

                </div>

            </aside>

        </main>

    </div>



    <div id="mission-modal">

        <div class="modal-content shadow-2xl">

            <h2 id="modal-title" class="text-2xl font-bold mb-4 mono uppercase"></h2>

            <div id="modal-body" class="space-y-4 mb-6 text-sm text-slate-300"></div>

            <button onclick="closeModal()" class="w-full py-3 bg-cyan-600 text-white font-bold rounded uppercase mono hover:bg-cyan-500 transition-colors">Ricevuto</button>

        </div>

    </div>



    <script>

        const canvas = document.getElementById('space-canvas');

        const ctx = canvas.getContext('2d');

        let objects = [];

        let stars = [];



        function initBackground() {

            resizeCanvas(false);

            generateStars();

            window.addEventListener('resize', () => resizeCanvas(true));

            animateSpace();

        }



        function generateStars() {

            const starColors = ['#ffffff', '#e2e8f0', '#93c5fd', '#fef9c3', '#fff7ed'];

            stars = [];

            const starCount = Math.floor((canvas.width * canvas.height) / 4000);

            for(let i=0; i<starCount; i++) {

                const rand = Math.random();

                let size, opacity;

                if (rand > 0.95) { size = 1.8 + Math.random() * 1.5; opacity = 0.8 + Math.random() * 0.2; }

                else if (rand > 0.7) { size = 0.8 + Math.random() * 1.0; opacity = 0.6 + Math.random() * 0.3; }

                else { size = 0.3 + Math.random() * 0.5; opacity = 0.3 + Math.random() * 0.4; }

                stars.push({

                    x: Math.random() * canvas.width,

                    y: Math.random() * canvas.height,

                    size: size,

                    color: starColors[Math.floor(Math.random() * starColors.length)],

                    opacity: opacity,

                    flickerSpeed: 0.01 + Math.random() * 0.04,

                    flickerPhase: Math.random() * Math.PI * 2

                });

            }

        }



        function resizeCanvas(regenerate) {

            canvas.width = window.innerWidth;

            canvas.height = window.innerHeight;

            if (regenerate) generateStars();

        }



        class SpaceObject {

            constructor() { this.reset(); }

            reset() {

                this.type = Math.random() > 0.5 ? 'ship' : 'meteor';

                this.size = this.type === 'meteor' ? (25 + Math.random() * 35) : (18 + Math.random() * 15);

                this.rotation = Math.random() * Math.PI * 2;

                this.rotSpeed = (Math.random() - 0.5) * 0.02;

                if (this.type === 'meteor') {

                    this.points = [];

                    for(let i=0; i<8; i++) {

                        let angle = (i/8) * Math.PI * 2;

                        let r = (this.size/2) * (0.7 + Math.random() * 0.5);

                        this.points.push({x: Math.cos(angle) * r, y: Math.sin(angle) * r});

                    }

                }

                const side = Math.floor(Math.random() * 4);

                const padding = 150;

                if (side === 0) { this.x = Math.random() * canvas.width; this.y = -padding; this.vx = (Math.random() - 0.5) * 1.2; this.vy = 0.4 + Math.random() * 0.8; }

                else if (side === 1) { this.x = canvas.width + padding; this.y = Math.random() * canvas.height; this.vx = -0.4 - Math.random() * 0.8; this.vy = (Math.random() - 0.5) * 1; }

                else if (side === 2) { this.x = Math.random() * canvas.width; this.y = canvas.height + padding; this.vx = (Math.random() - 0.5) * 1.2; this.vy = -0.4 - Math.random() * 0.8; }

                else { this.x = -padding; this.y = Math.random() * canvas.height; this.vx = 0.4 + Math.random() * 0.8; this.vy = (Math.random() - 0.5) * 1; }

                this.active = false;

                this.delay = 100 + Math.random() * 500;

                this.engineTimer = 0;

            }

            update() {

                if (this.delay > 0) { this.delay--; return; }

                this.active = true;

                this.x += this.vx; this.y += this.vy;

                this.rotation += this.rotSpeed; this.engineTimer += 0.25;

                if (this.x < -400 || this.x > canvas.width + 400 || this.y < -400 || this.y > canvas.height + 400) this.reset();

            }

            draw() {

                if (!this.active) return;

                ctx.save();

                if (this.type === 'ship') {

                    ctx.translate(this.x, this.y); ctx.rotate(Math.atan2(this.vy, this.vx) + Math.PI/2);

                    const flicker = Math.sin(this.engineTimer * 6) * 8;

                    const grad = ctx.createLinearGradient(0, 0, 0, this.size * 1.2);

                    grad.addColorStop(0, 'rgba(56, 189, 248, 0.9)'); grad.addColorStop(1, 'rgba(56, 189, 248, 0)');

                    ctx.fillStyle = grad; ctx.beginPath(); ctx.moveTo(-this.size/4, this.size/4); ctx.lineTo(0, this.size + flicker); ctx.lineTo(this.size/4, this.size/4); ctx.fill();

                    ctx.fillStyle = '#cbd5e1'; ctx.beginPath(); ctx.moveTo(0, -this.size/2); ctx.lineTo(this.size/2.5, this.size/3); ctx.lineTo(0, this.size/5); ctx.lineTo(-this.size/2.5, this.size/3); ctx.closePath(); ctx.fill();

                    ctx.fillStyle = '#0ea5e9'; ctx.beginPath(); ctx.ellipse(0, -this.size/8, this.size/7, this.size/10, 0, 0, Math.PI*2); ctx.fill();

                } else {

                    ctx.translate(this.x, this.y); ctx.rotate(this.rotation);

                    ctx.fillStyle = '#0f172a'; ctx.beginPath(); ctx.moveTo(this.points[0].x+2, this.points[0].y+2);

                    for(let i=1; i<this.points.length; i++) ctx.lineTo(this.points[i].x+2, this.points[i].y+2);

                    ctx.fill();

                    ctx.fillStyle = '#334155'; ctx.strokeStyle = '#475569'; ctx.lineWidth = 1;

                    ctx.beginPath(); ctx.moveTo(this.points[0].x, this.points[0].y);

                    for(let i=1; i<this.points.length; i++) ctx.lineTo(this.points[i].x, this.points[i].y);

                    ctx.closePath(); ctx.fill(); ctx.stroke();

                }

                ctx.restore();

            }

        }



        function animateSpace() {

            ctx.clearRect(0, 0, canvas.width, canvas.height);

            stars.forEach(s => {

                s.flickerPhase += s.flickerSpeed;

                const dynamicOpacity = s.opacity * (0.8 + Math.sin(s.flickerPhase) * 0.2);

                ctx.globalAlpha = dynamicOpacity; ctx.fillStyle = s.color;

                ctx.beginPath(); ctx.arc(s.x, s.y, s.size/2, 0, Math.PI*2); ctx.fill();

            });

            ctx.globalAlpha = 1.0;

            if (objects.length < 5 && Math.random() > 0.99) objects.push(new SpaceObject());

            objects.forEach(obj => { obj.update(); obj.draw(); });

            requestAnimationFrame(animateSpace);

        }



        /**

         * LOGICA APPLICATIVO

         */

        let availableCharacters = [];

        let team = [];

        let missionHistory = [];

        let viewMode = 'alive';

        const MAX_TEAM = 3;

        const TARGET_COUNT = 10;



        async function init() {

            initBackground();

            try {

                // Caricamento iniziale sicuro

                const ids = Array.from({length: TARGET_COUNT}, (_, i) => i + 1);

                const response = await fetch(`https://rickandmortyapi.com/api/character/${ids.join(',')}`);

                if(!response.ok) throw new Error("API Offline");

                const data = await response.json();

                availableCharacters = data.map(char => createCharacterObject(char));

                renderDisplay();

            } catch (error) {

                console.error("Errore database:", error);

                // Fallback minimo se API fallisce all'avvio

                showModal("Errore Connessione", "Impossibile collegarsi al database centrale Rick & Morty. Riprovare tra poco.");

            }

        }



        function createCharacterObject(char) {

            return {

                ...char,

                status: char.status === 'Dead' ? 'Alive' : char.status, // Forza Alive per le nuove reclute

                isRecruited: false,

                stats: {

                    lavoro: Math.floor(Math.random() * 60) + 40,

                    informatica: Math.floor(Math.random() * 60) + 40,

                    combattimento: Math.floor(Math.random() * 60) + 40

                }

            };

        }



        function toggleView() {

            viewMode = viewMode === 'alive' ? 'dead' : 'alive';

            const sidebar = document.getElementById('team-sidebar');

            const mainContent = document.getElementById('main-content-area');

            if (viewMode === 'dead') { sidebar.classList.add('hidden'); mainContent.classList.replace('xl:col-span-3', 'xl:col-span-4'); }

            else { sidebar.classList.remove('hidden'); mainContent.classList.replace('xl:col-span-4', 'xl:col-span-3'); }

            renderDisplay();

        }



        async function refreshRecruits() {

            // Identifica chi è nel team MISSIONE o DISPERSO

            const recruitedIds = team.map(m => m.id);

            const deadIds = availableCharacters.filter(c => c.status === 'Dead').map(c => c.id);

           

            // Mantieni sia i reclutati che i morti (dispersei)

            const keepIds = [...new Set([...recruitedIds, ...deadIds])];

           

            // Filtra l'array locale: tieni solo chi vogliamo preservare

            availableCharacters = availableCharacters.filter(c => keepIds.includes(c.id));

           

            // Calcola quante nuove unità "Alive" servono

            const currentAliveCount = availableCharacters.filter(c => c.status === 'Alive').length;

            const needed = TARGET_COUNT - currentAliveCount;

           

            if (needed <= 0) {

                renderDisplay();

                return;

            }



            const newIds = [];

            while(newIds.length < needed) {

                const randId = Math.floor(Math.random() * 800) + 1;

                if (!availableCharacters.some(c => c.id === randId) && !newIds.includes(randId)) {

                    newIds.push(randId);

                }

            }



            try {

                // Sicurezza: se per qualche motivo newIds è vuoto, non chiamare l'API

                if (newIds.length === 0) return;



                const response = await fetch(`https://rickandmortyapi.com/api/character/${newIds.join(',')}`);

                if (!response.ok) throw new Error("API Fetch Error");

               

                const data = await response.json();

                const newChars = Array.isArray(data) ? data : [data];

               

                newChars.forEach(c => {

                    if (c && c.id) {

                        availableCharacters.push(createCharacterObject(c));

                    }

                });

               

                renderDisplay();

            } catch (e) {

                console.error("Errore rinforzi:", e);

                // In caso di errore API, mostriamo almeno quello che abbiamo salvato

                renderDisplay();

            }

        }



        function renderDisplay() {

            const grid = document.getElementById('candidates-grid');

            const label = document.getElementById('tab-label');

            const icon = document.getElementById('tab-icon');

            grid.innerHTML = '';

           

            const filteredUnits = availableCharacters.filter(c => c.status === (viewMode === 'alive' ? 'Alive' : 'Dead'));

           

            if (viewMode === 'alive') {

                label.innerText = 'UNITÀ OPERATIVE DISPONIBILI';

                icon.className = 'w-2 h-2 bg-emerald-400 rounded-full animate-ping';

                label.className = 'text-emerald-400';

            } else {

                label.innerText = 'UNITÀ OPERATIVE DISPERSE';

                icon.className = 'w-2 h-2 bg-red-500 rounded-full';

                label.className = 'text-red-500';

            }



            if (filteredUnits.length === 0) {

                grid.innerHTML = `<p class="col-span-full text-slate-600 italic mono py-20 uppercase text-center">Nessuna unità rilevata in questo settore</p>`;

                return;

            }



            filteredUnits.forEach(char => {

                const isDead = char.status === 'Dead';

                const card = document.createElement('div');

                card.className = `glass-panel character-card ${isDead ? 'status-dead' : 'status-alive'} flex flex-col`;

                card.id = `card-${char.id}`;

               

                let actionButton = !isDead

                    ? (char.isRecruited ? `<button disabled class="btn-action w-full py-2 text-[9px] uppercase font-bold rounded">Unità Reclutata</button>` : `<button onclick="recruit(${char.id})" class="btn-action w-full py-2 text-[9px] uppercase font-bold rounded">Recluta Unità</button>`)

                    : `<p class="text-[9px] text-red-500 mono text-center uppercase tracking-tighter">Segnale Perso</p>`;

               

                card.innerHTML = `

                    <div class="portrait-container">

                        <div class="hud-overlay"></div>

                        <img src="${char.image}" class="portrait-bg-blur" onerror="this.src='https://via.placeholder.com/300x300/0f172a/60a5fa?text=NA'">

                        <img src="${char.image}" class="portrait-img" onerror="this.src='https://via.placeholder.com/300x300/0f172a/60a5fa?text=NA'">

                    </div>

                    <div class="p-4 flex-grow">

                        <h3 class="text-sm font-bold truncate uppercase tracking-tight">${char.name}</h3>

                        <p class="text-[10px] text-slate-500 mb-3 mono uppercase">${char.species}</p>

                        <div class="dossier-wrapper mb-4">

                            <button onclick="toggleDossier(${char.id})" class="w-full text-left text-[9px] font-bold text-cyan-400 flex justify-between items-center py-2 border-t border-white/5">

                                <span>DATI BIOMETRICI</span>

                                <span>▼</span>

                            </button>

                            <div class="dossier-details space-y-2">

                                <div>

                                    <div class="flex justify-between text-[8px] mono"><span>LOGISTICA</span><span>${char.stats.lavoro}%</span></div>

                                    <div class="stat-bar-bg"><div class="stat-bar-fill" style="width: ${char.stats.lavoro}%"></div></div>

                                </div>

                                <div>

                                    <div class="flex justify-between text-[8px] mono"><span>SISTEMI</span><span>${char.stats.informatica}%</span></div>

                                    <div class="stat-bar-bg"><div class="stat-bar-fill" style="width: ${char.stats.informatica}%"></div></div>

                                </div>

                                <div>

                                    <div class="flex justify-between text-[8px] mono"><span>ATTACCO</span><span>${char.stats.combattimento}%</span></div>

                                    <div class="stat-bar-bg"><div class="stat-bar-fill" style="width: ${char.stats.combattimento}%"></div></div>

                                </div>

                            </div>

                        </div>

                        ${actionButton}

                    </div>`;

                grid.appendChild(card);

            });

        }



        function toggleDossier(id) {

            const el = document.getElementById(`card-${id}`);

            if(el) el.classList.toggle('dossier-open');

        }



        function recruit(id) {

            if (team.length >= MAX_TEAM) return;

            const char = availableCharacters.find(c => c.id === id);

            if (!char || team.some(m => m.id === id)) return;

            char.isRecruited = true;

            team.push(char);

            updateTeamUI();

            renderDisplay();

        }



        function remove(id) {

            const char = availableCharacters.find(c => c.id === id);

            if (char) char.isRecruited = false;

            team = team.filter(m => m.id !== id);

            updateTeamUI();

            renderDisplay();

        }



        function updateTeamUI() {

            const list = document.getElementById('team-list');

            list.innerHTML = '';

            team.forEach(m => {

                const item = document.createElement('div');

                item.className = "flex justify-between items-center p-3 bg-cyan-500/5 border border-cyan-500/20 rounded text-xs";

                item.innerHTML = `

                    <span class="truncate pr-2">${m.name}</span>

                    <button onclick="remove(${m.id})" class="text-red-500 hover:text-red-400 mono text-[10px] ml-2">CONGEDA</button>`;

                list.appendChild(item);

            });

            document.getElementById('team-count').innerText = `${team.length} / ${MAX_TEAM}`;

            document.getElementById('launch-btn').disabled = team.length === 0;

        }



        async function startMission() {

            const success = Math.random() > 0.5;

            let report = "";

            let missionEntry = { id: Date.now(), success: success, time: new Date().toLocaleTimeString(), survivors: [], lost: [] };

           

            team.forEach(m => {

                const survived = (Math.random() * 100) < (success ? 70 : 40);

                const charIndex = availableCharacters.findIndex(c => c.id === m.id);

               

                if (charIndex !== -1) {

                    if (!survived) {

                        availableCharacters[charIndex].status = 'Dead';

                        availableCharacters[charIndex].isRecruited = false;

                        missionEntry.lost.push(m.name);

                        report += `<p class="text-red-400 mono text-xs uppercase">✘ disperso: ${m.name}</p>`;

                    } else {

                        availableCharacters[charIndex].isRecruited = false;

                        missionEntry.survivors.push(m.name);

                        report += `<p class="text-emerald-400 mono text-xs uppercase">✔ rientrato: ${m.name}</p>`;

                    }

                }

            });

           

            missionHistory.unshift(missionEntry);

            updateHistoryUI();

            showModal(success ? "Missione Compiuta" : "Fallimento Critico", report);

            team = [];

            updateTeamUI();

            renderDisplay();

        }



        function updateHistoryUI() {

            const container = document.getElementById('mission-history-content');

            if (!container) return;

            container.innerHTML = '';

            missionHistory.forEach(log => {

                const item = document.createElement('div');

                item.className = "border border-white/5 bg-slate-950/80 rounded overflow-hidden";

                item.innerHTML = `

                    <details class="group">

                        <summary class="p-3 flex justify-between items-center cursor-pointer hover:bg-white/5 transition-colors">

                            <span class="text-[10px] mono font-bold ${log.success ? 'text-emerald-400' : 'text-red-500'}">

                                [${log.success ? 'OK' : 'ER'}] REGISTRO_${log.time.replace(/:/g, '')}

                            </span>

                            <span class="text-xs text-slate-500 group-open:rotate-180">▼</span>

                        </summary>

                        <div class="p-4 pt-0 border-t border-white/5 text-[9px] mono space-y-2">

                            <div><span class="text-slate-500">SUPERSTITI:</span><p>${log.survivors.join(', ') || 'NESSUNO'}</p></div>

                            <div><span class="text-slate-500">PERDITE:</span><p class="text-red-400">${log.lost.join(', ') || 'NESSUNA'}</p></div>

                        </div>

                    </details>`;

                container.appendChild(item);

            });

        }



        function showModal(title, body) {

            const modalTitle = document.getElementById('modal-title');

            modalTitle.innerText = title;

            modalTitle.className = `text-2xl font-bold mb-4 mono uppercase ${title.includes("Compiuta") ? 'text-emerald-400' : 'text-red-500'}`;

            document.getElementById('modal-body').innerHTML = body;

            document.getElementById('mission-modal').style.display = 'flex';

        }



        function closeModal() { document.getElementById('mission-modal').style.display = 'none'; }

       

        window.onload = init;

    </script>

</body>

</html>
